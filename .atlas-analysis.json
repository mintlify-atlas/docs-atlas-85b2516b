  "keyFeatures": [
    "Deploy your own Web3 prediction market in minutes",
    "Polygon-native with low fees and USDC settlements",
    "UMA-powered decentralized oracle for market resolution",
    "On-chain affiliate attribution and fee sharing",
    "Bot-ready APIs with Python and Rust SDKs",
    "Full trading interface with order book and position management",
    "Multi-deployment options: Vercel, Docker, Kubernetes, Cloud providers",
    "Admin dashboard for branding, fees, and market management",
    "Shared liquidity across multiple market forks",
    "Safe-compatible proxy wallet support"
  ],
  "publicApiSurface": [
    "GET /api/markets - List all markets",
    "GET /api/markets/{id} - Get market details",
    "GET /api/markets/{id}/orderbook - Get market order book",
    "GET /api/events - List events",
    "GET /api/user/positions - Get user positions",
    "GET /api/user/orders - Get user orders",
    "POST /api/lifi/quote - Get liquidity bridge quote",
    "GET /api/holders - Get top holders",
    "GET /api/event-activity - Get event activity",
    "GET /api/users/leaderboard - Get trader leaderboard",
    "POST /auth/login - Authenticate user",
    "WebSocket /api/wss - Real-time market updates"
  ]
